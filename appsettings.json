{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
    "EmailSettings": {
      "SmtpServer": "smtp.gmail.com",
      "SmtpPort": 587,
      "SmtpUsername": "your-email@gmail.com",
      "SmtpPassword": "your-app-password",
      "SenderEmail": "your-email@gmail.com",
      "UseSsl": true
    },
    "AppSettings": {
      "ClientUrl": "http://localhost:3000"
    },
  "JWT": {
    "Key": "your-secret-key-min-32-chars",
    "Issuer": "ExaminationSystem",
    "Audience": "ExaminationSystem"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ExamElevate;Trusted_Connection=true;TrustServerCertificate=true"
  }
}
